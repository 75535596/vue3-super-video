{
  "name": "vue3-super-video",
  "version": "1.0.8",
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "vue3-super-video.d.ts"
  ],
  "main": "./dist/vue3-super-video.umd.cjs",
  "module": "./dist/vue3-super-video.js",
  "types": "./vue3-super-video.d.ts",
  "exports": {
    "./dist/vue3-super-video.css": "./dist/vue3-super-video.css",
    "./css": "./dist/vue3-super-video.css",
    "./types": "./vue3-super-video.d.ts",
    "./api/types": "./dist/api/types.d.ts",
    ".": {
      "types": "./vue3-super-video.d.ts",
      "import": "./dist/vue3-super-video.js",
      "require": "./dist/vue3-super-video.umd.cjs"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build-project": "vite build --config vite.project.config.ts",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/ packages/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:report": "vitest run --coverage"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/coverage-v8": "3.2.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.22.0",
    "eslint-plugin-oxlint": "^0.16.0",
    "eslint-plugin-vue": "~10.0.0",
    "jiti": "^2.4.2",
    "less": "^4.4.0",
    "npm-run-all2": "^7.0.2",
    "oxlint": "^0.16.0",
    "postcss-prefix-selector": "^2.1.1",
    "prettier": "3.5.3",
    "rollup-plugin-copy": "^3.5.0",
    "sass": "^1.87.0",
    "sass-loader": "^16.0.5",
    "terser": "^5.39.0",
    "typescript": "~5.8.0",
    "vite": "^6.2.4",
    "vue-tsc": "^2.2.8"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "element-plus": "^2.10.5"
  },
  "peerDependencies": {
    "@types/vue": "^2.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^27.0.0",
    "lodash-es": "^4.17.21",
    "pinia": "^3.0.1",
    "qs": "^6.14.0",
    "sm-crypto": "^0.3.13",
    "vitest": "^3.2.4",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  }
}
